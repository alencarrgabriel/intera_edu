# Application
NODE_ENV=development

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=interaedu
DATABASE_USERNAME=interaedu
DATABASE_PASSWORD=interaedu_dev_password
DATABASE_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@interaedu.com

# S3 (Object Storage — MinIO for dev)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=interaedu
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Service Ports
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
PROFILE_SERVICE_PORT=3002
FEED_SERVICE_PORT=3003
MESSAGING_SERVICE_PORT=3004
